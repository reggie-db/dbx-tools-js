{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    // The flat editor `tsconfig.json` carries `DOM` for the UI packages;
    // node-side builds stay DOM-free (UI build configs re-add `DOM`).
    "lib": ["ESNext"],
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}",
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["${configDir}/index.ts", "${configDir}/src", "${configDir}/generated"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/tmp",
    "${configDir}/dist",
    "${configDir}/test",
    "${configDir}/**/*.test.ts"
  ]
}
