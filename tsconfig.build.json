{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}",
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["${configDir}/index.ts", "${configDir}/src"],
  "exclude": ["${configDir}/dist", "${configDir}/tests", "${configDir}/**/*.test.ts"]
}
