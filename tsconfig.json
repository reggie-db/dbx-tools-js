{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "customConditions": ["source"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": [
    "${configDir}/index.ts",
    "${configDir}/src",
    "${configDir}/generated",
    "${configDir}/test"
  ],
  "exclude": ["**/node_modules", "**/dist", "**/build", "**/tmp"],
  "files": [],
  "references": [
    {
      "path": "./demo/tsconfig.json"
    },
    {
      "path": "./packages/appkit-config/tsconfig.build.json"
    },
    {
      "path": "./packages/appkit-mastra-shared/tsconfig.build.json"
    },
    {
      "path": "./packages/appkit-mastra-ui/tsconfig.build.json"
    },
    {
      "path": "./packages/appkit-mastra-ui/tsconfig.json"
    },
    {
      "path": "./packages/appkit-mastra/tsconfig.build.json"
    },
    {
      "path": "./packages/auth/tsconfig.build.json"
    },
    {
      "path": "./packages/genie-shared/tsconfig.build.json"
    },
    {
      "path": "./packages/genie/tsconfig.build.json"
    },
    {
      "path": "./packages/model-shared/tsconfig.build.json"
    },
    {
      "path": "./packages/model/tsconfig.build.json"
    },
    {
      "path": "./packages/sdk-shared/tsconfig.build.json"
    },
    {
      "path": "./packages/shared/tsconfig.build.json"
    }
  ]
}
