{
  "files": [],
  "references": [
    {
      "path": "./demo/tsconfig.json"
    },
    {
      "path": "./packages/arize/tsconfig.build.json"
    },
    {
      "path": "./packages/autopg/tsconfig.build.json"
    },
    {
      "path": "./packages/mastra-shared/tsconfig.build.json"
    },
    {
      "path": "./packages/mastra/tsconfig.build.json"
    },
    {
      "path": "./packages/serving/tsconfig.build.json"
    },
    {
      "path": "./packages/shared/tsconfig.build.json"
    }
  ],
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "customConditions": ["source"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": ["**/node_modules", "**/dist", "**/build", "**/tmp"]
}
