{
  "name": "@dbx-tools/appkit-mastra-ui",
  "version": "0.1.0",
  "description": "React <MastraChat> component for @dbx-tools/appkit-mastra, backed by the AI SDK v5 useChat hook and the AI Elements components used in https://ui-dojo.mastra.ai/.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["databricks", "appkit", "react", "chat", "mastra", "ai-sdk"],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.114",
    "@dbx-tools/appkit-mastra-shared": "workspace:*",
    "ai": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.554.0",
    "streamdown": "^1.6.10",
    "tailwind-merge": "^3.4.0",
    "use-stick-to-bottom": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
