{
  "name": "@dbx-tools/appkit-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "NODE_ENV=development NODE_OPTIONS='--conditions=source' tsx watch --tsconfig ./tsconfig.server.json --env-file-if-exists=./.env ./server/server.ts",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc -b tsconfig.server.json",
    "build": "bun run build:server && bun run build:client",
    "typecheck": "tsc -b tsconfig.server.json && tsc -b tsconfig.client.json",
    "clean": "rm -rf dist client/dist *.tsbuildinfo"
  },
  "dependencies": {
    "@databricks/appkit": "^0.33.0",
    "@databricks/appkit-ui": "^0.33.0",
    "@dbx-tools/appkit-genie": "workspace:*",
    "@dbx-tools/appkit-genie-ui": "workspace:*",
    "@dbx-tools/appkit-mastra": "workspace:*",
    "@dbx-tools/appkit-mastra-shared": "workspace:*",
    "@dbx-tools/appkit-mastra-ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.1.0"
  }
}
