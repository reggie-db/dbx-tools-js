{
  "name": "@dbx-tools/appkit-genie-ui",
  "version": "0.1.0",
  "description": "React <AgentChat> component for @dbx-tools/appkit-genie, styled to match @databricks/appkit-ui.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
