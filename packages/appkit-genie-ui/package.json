    "marked": "^16.0.0"
  },
  "devDependencies": {
    "@databricks/appkit-ui": "^0.33.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
