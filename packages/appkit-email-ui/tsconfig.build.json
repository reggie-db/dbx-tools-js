{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "rootDir": "${configDir}/src",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    // Browser/React package consumed through a bundler. `bundler`
    // resolution + ts-extension rewriting matches `appkit-mastra-ui`:
    // it lets workspace deps resolve to raw `.ts` source via the
    // `source` condition while keeping emitted imports legal (`.js`).
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["${configDir}/src"],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/tmp",
    "${configDir}/dist",
    "${configDir}/**/*.test.ts",
    "${configDir}/**/*.test.tsx"
  ]
}
