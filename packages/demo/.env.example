# Databricks workspace + auth (use OAuth-U2M for local dev: `databricks auth login --host <host>`).
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Model serving endpoint name that the analyst agent runs on.
DATABRICKS_SERVING_ENDPOINT_NAME=databricks-claude-sonnet-4-6

# Genie space the demo is wired to. With this set, the genie plugin's `default`
# space is populated, dbxTools auto-wires it during `setup:complete`, and the
# agent receives a single `genie` tool.
DATABRICKS_GENIE_SPACE_ID=01a0b2c3d4e5f6789012345678901234

# Lakebase Autoscaling wiring. These names match the resources declared in
# `databricks.yml`; running `databricks bundle deploy` from this directory
# creates a single autoscaling Postgres endpoint (0.5-2 CU, scale-to-zero
# after 5min idle) and the names below resolve to it deterministically.
LAKEBASE_BRANCH=projects/dbx-tools-demo/branches/main
LAKEBASE_DATABASE=projects/dbx-tools-demo/branches/main/databases/databricks_postgres
LAKEBASE_ENDPOINT=projects/dbx-tools-demo/branches/main/endpoints/primary

# Postgres connection params. PGHOST is endpoint-specific and only known after
# deploy. Look it up with:
#   databricks postgres get-endpoint projects/dbx-tools-demo/branches/main/endpoints/primary
# and paste the `status.hosts.host` value below.
PGHOST=
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require

# Optional: only set OPENAI_API_KEY if you've overridden `memory.embedder` /
# `memory.llm` in dbxTools() config to point at OpenAI proper. The default
# wires both at the Databricks Foundation Model API
# (`databricks-gte-large-en` for embeddings, `databricks-meta-llama-3-3-70b-
# instruct` for the memory-extraction LLM) using an OAuth bearer minted from
# DATABRICKS_CONFIG_PROFILE - no OpenAI key required.
# OPENAI_API_KEY=sk-...
