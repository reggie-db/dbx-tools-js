{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    // `@mastra/mcp` (and its `@modelcontextprotocol/sdk` chain) pull
    // transitive deps like `eventsource` / `eventsource-parser` that
    // resolve to raw `.ts` source via the workspace `source` condition.
    // The root build's NodeNext settings reject those `.ts` imports, so
    // - exactly like `appkit-mastra-ui` - this package compiles under
    // `bundler` resolution + `allowImportingTsExtensions`, with
    // `rewriteRelativeImportExtensions` keeping our own `.js` emit legal.
    // `eventsource` itself is pinned to its `.d.ts` in the root config's
    // `paths` so `skipLibCheck` covers its uncompilable source.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  }
}
