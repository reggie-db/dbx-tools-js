{
  "name": "@dbx-tools/appkit-demo",
  "version": "1.0.0",
  "dependencies": {
    "@databricks/appkit": "catalog:",
    "@databricks/appkit-ui": "catalog:",
    "@databricks/sdk-experimental": "catalog:",
    "@dbx-tools/appkit-config": "workspace:*",
    "@dbx-tools/appkit-email": "workspace:*",
    "@dbx-tools/appkit-mastra": "workspace:*",
    "@dbx-tools/appkit-mastra-ui": "workspace:*",
    "@dbx-tools/appkit-ui": "workspace:*",
    "@dbx-tools/shared": "workspace:*",
    "@mastra/ai-sdk": "catalog:",
    "@mastra/core": "catalog:",
    "@mastra/express": "catalog:",
    "@mastra/fastembed": "catalog:",
    "@mastra/mcp": "catalog:",
    "@mastra/memory": "catalog:",
    "@mastra/observability": "catalog:",
    "@mastra/otel-bridge": "catalog:",
    "@mastra/pg": "catalog:",
    "@opentelemetry/api": "catalog:",
    "express": "catalog:",
    "fast-deep-equal": "catalog:",
    "fuse.js": "^7.4.2",
    "juice": "^12.1.1",
    "lucide-react": "catalog:",
    "marked": "catalog:",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "streamdown": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "^4.22.4"
  },
  "license": "Apache-2.0",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "build": "bun run build:server && bun run build:client",
    "build:client": "NODE_ENV=production bun ./client/build.ts",
    "build:server": "tsc -b tsconfig.server.json && tsdown -c tsdown.server.config.ts",
    "clean": "rm -rf client/dist client/src/.generated dist build .smoke-test test-results playwright-report",
    "dev": "bun ./client/build.ts && bun run --parallel dev:client dev:server",
    "dev:client": "bun ./client/build.ts --watch",
    "dev:server": "NODE_ENV=development NODE_OPTIONS='--conditions=source' bunx tsx watch --tsconfig ./tsconfig.server.json --env-file-if-exists=../.env ./server/server.ts",
    "setup": "appkit setup --write",
    "start": "NODE_ENV=production node --env-file-if-exists=../.env dist/server.js",
    "sync": "appkit plugin sync --write --silent",
    "typecheck": "tsc -b tsconfig.server.json tsconfig.client.json",
    "typegen": "appkit generate-types"
  },
  "type": "module"
}
