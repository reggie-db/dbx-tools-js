{
  "name": "@dbx-tools/appkit-demo",
  "version": "1.0.0",
  "dependencies": {
    "@ai-sdk/react": "^2.0.114",
    "@databricks/appkit": "catalog:",
    "@databricks/appkit-ui": "catalog:",
    "@dbx-tools/appkit-config": "workspace:*",
    "@dbx-tools/appkit-mastra": "workspace:*",
    "@dbx-tools/appkit-mastra-shared": "workspace:*",
    "@dbx-tools/appkit-mastra-ui": "workspace:*",
    "@dbx-tools/genie-shared": "workspace:*",
    "@dbx-tools/sdk-shared": "workspace:*",
    "@dbx-tools/shared": "workspace:*",
    "@mastra/client-js": "catalog:",
    "ai": "5.0.193",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7",
    "tw-animate-css": "^1.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "5.1.0",
    "tailwindcss": "^4.1.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.20.0",
    "vite": "^7.1.0"
  },
  "license": "Apache-2.0",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "build": "bun run build:server && bun run build:client",
    "build:client": "bunx -bun vite build --config client/vite.config.ts",
    "build:server": "tsc -b tsconfig.server.json && tsdown -c tsdown.server.config.ts",
    "clean": "rm -rf client/dist dist build .smoke-test test-results playwright-report",
    "dev": "NODE_ENV=development NODE_OPTIONS='--conditions=source' tsx watch --tsconfig ./tsconfig.server.json --env-file-if-exists=../.env ./server/server.ts",
    "setup": "appkit setup --write",
    "start": "NODE_ENV=production node --env-file-if-exists=./.env ./dist/server.js",
    "sync": "appkit plugin sync --write --silent",
    "typecheck": "tsc -b tsconfig.server.json tsconfig.client.json",
    "typegen": "appkit generate-types"
  },
  "type": "module"
}
