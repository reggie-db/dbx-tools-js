node_modules

# Build output. The bundler (tsdown) emits each publishable package's
# JS + .d.ts into `<pkg>/dist`; the editor/typecheck program and the
# IDE watchers (see .vscode/settings.json) exclude it.
dist
client/dist

# Incremental tsc state. Demo's split build writes these under
# node_modules/.tmp; anything else lands in node_modules/.cache. Either
# way it stays out of the source tree and out of git.
*.tsbuildinfo
node_modules/.cache

.env
tmp

# Local AI tooling state (Claude Code, etc.) - machine-specific, never shared.
.claude

# bun.lock is uncommitted because it bakes in the registry URLs of whoever
# ran `bun install` (e.g. a corporate npm proxy), which we don't want
# leaking to the public repo or to other contributors.
bun.lock

# AppKit's postinstall hook drops a starter plugin scaffold here.
# We're a workspace of pre-built AppKit plugins so we don't want it.
/plugins
