  "scripts": {
    "build": "bun packages/devkit/bin/devkit.ts build",
    "clean": "rm -rf packages/*/dist demo/dist demo/client/dist demo/node_modules/.cache node_modules/.cache",
    "codegen": "bun packages/devkit/bin/devkit.ts codegen",
    "create": "bun packages/devkit/bin/devkit.ts create",
    "dev": "bun run --cwd=demo dev",
    "format": "bun packages/devkit/bin/devkit.ts format",
