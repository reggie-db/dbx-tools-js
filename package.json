    "tag": "bun packages/devkit/bin/devkit.ts tag",
    "typecheck": "tsc --noEmit -p tsconfig.json && bun run --cwd=demo typecheck",
    "verify": "bun packages/devkit/bin/devkit.ts verify",
    "version": "bunx --bun changeset version"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
