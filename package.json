{
  "name": "dbx-tools-appkit",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test packages",
    "dev": "bun --elide-lines=0 run --filter '@dbx-tools/appkit-demo' dev",
    "create": "bun scripts/create-package.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@databricks/appkit": "^0.35.0",
    "@types/bun": "^1.3.13",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "zod": "4.3.6"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.0-canary.125",
    "@mastra/ai-sdk": "^0.0.0-fix-buildmessagesfromchunks-message-part-ordering-20260507134311",
    "ai": "^7.0.0-canary.125"
  }
}
