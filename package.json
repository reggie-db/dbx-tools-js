{
  "name": "dbx-tools-appkit",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "typecheck": "bun scripts/typecheck.ts",
    "clean": "bun scripts/clean.ts",
    "build": "bun scripts/build.ts",
    "create": "bun scripts/create-package.ts",
    "version": "bunx changeset version",
    "release": "bun scripts/build.ts && bun scripts/publish.ts",
    "dev": "bun --elide-lines=0 run --filter '@dbx-tools/appkit-demo' dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@databricks/appkit": "^0.35.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^24",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "zod": "4.3.6"
  }
}
