{
  "name": "dbx-tools-appkit",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "dev": "bun --elide-lines=0 run --filter '@dbx-tools/appkit-demo' dev",
    "create": "bun scripts/create-package.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@databricks/appkit": "^0.33.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "zod": "4.3.6"
  }
}
