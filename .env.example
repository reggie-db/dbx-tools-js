# Databricks workspace + auth (use OAuth-U2M for local dev: `databricks auth login --host <host>`).
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Model serving endpoint name that the analyst agent runs on. Defaults
# to the latest Claude Opus; tweak to a Sonnet (`databricks-claude-sonnet-4-6`)
# or Haiku (`databricks-claude-haiku-4-5`) variant to trade quality for
# latency / cost. Loose names like `claude opus` also work because the
# Mastra plugin fuzzy-matches against the workspace's live
# `/serving-endpoints` catalogue.
DATABRICKS_SERVING_ENDPOINT_NAME=databricks-claude-opus-4-8

# Genie space the demo is wired to. With this set, the genie plugin's `default`
# space is populated, dbxTools auto-wires it during `setup:complete`, and the
# agent receives a single `genie` tool.
DATABRICKS_GENIE_SPACE_ID=01a0b2c3d4e5f6789012345678901234

# Lakebase Autoscaling wiring. These names match the resources declared in
# `databricks.yml`; running `databricks bundle deploy` from this directory
# creates a single autoscaling Postgres endpoint (0.5-2 CU, scale-to-zero
# after 5min idle) and the names below resolve to it deterministically.
LAKEBASE_BRANCH=projects/dbx-tools-demo/branches/main
LAKEBASE_DATABASE=projects/dbx-tools-demo/branches/main/databases/databricks_postgres
LAKEBASE_ENDPOINT=projects/dbx-tools-demo/branches/main/endpoints/primary

# Postgres connection params. PGHOST is endpoint-specific and only known after
# deploy. Look it up with:
#   databricks postgres get-endpoint projects/dbx-tools-demo/branches/main/endpoints/primary
# and paste the `status.hosts.host` value below.
PGHOST=
PGDATABASE=databricks_postgres
PGPORT=5432
PGSSLMODE=require

# Outbound email (the `email()` plugin + approval-gated `send_email` tool).
# Point these at any SMTP provider (e.g. SMTP2GO). The sender address is
# derived from the on-behalf-of user: the local part of their email
# (everything before `@`) is re-homed on EMAIL_DOMAIN, so
# `alice@databricks.com` sends as `alice@${EMAIL_DOMAIN}`. Set EMAIL_FROM
# instead to send every message from one fixed address. In production,
# source SMTP_PASSWORD from a Databricks secret via app.yaml `valueFrom`.
#
# Leave SMTP_HOST / SMTP_USER / SMTP_PASSWORD unset to run in "outbox"
# mode: instead of sending, each approved email is written as HTML to
# EMAIL_OUTBOX_DIR (default <cwd>/tmp) under tmp/<sender>/<subject>.html,
# so you can test the approval flow with zero email config.
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_DOMAIN=example.com
# EMAIL_FROM=bot@example.com
# EMAIL_OUTBOX_DIR=tmp

# Optional: OTLP trace export. Point at the *base* URL of any OTLP/HTTP
# collector and AppKit's TelemetryManager will boot a NodeSDK at startup,
# shipping both AppKit plugin spans and Mastra spans (via
# `@mastra/otel-bridge`) to that endpoint. The OTel SDK appends the signal
# path (`/v1/traces`) automatically, so do *not* include it here. Start a
# local Phoenix collector with:
#   docker compose -f docker/phoenix.compose.yml up -d
# then uncomment the line below.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006

# Optional: only set OPENAI_API_KEY if you've overridden `memory.embedder` /
# `memory.llm` in dbxTools() config to point at OpenAI proper. The default
# wires both at the Databricks Foundation Model API
# (`databricks-gte-large-en` for embeddings, `databricks-meta-llama-3-3-70b-
# instruct` for the memory-extraction LLM) using an OAuth bearer minted from
# DATABRICKS_CONFIG_PROFILE - no OpenAI key required.
# OPENAI_API_KEY=sk-...
